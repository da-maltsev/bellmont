---
interface Props {
  title?: string;
  subtitle?: string;
  id?: string;
  class?: string;
}

const { title, subtitle, id, class: className = '' } = Astro.props;
---

<section id={id} class={`py-12 md:py-16 ${className}`}>
  <div class="max-w-7xl mx-auto px-4">
    {title && (
      <div class="text-center mb-12">
        <h2 class="font-playfair text-3xl md:text-4xl font-bold text-primary mb-4">
          {title}
        </h2>
        {subtitle && (
          <p class="text-gray-600 max-w-2xl mx-auto">
            {subtitle}
          </p>
        )}
      </div>
    )}
    <slot />
  </div>
</section>
