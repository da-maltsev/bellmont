---
interface Props {
  name: string;
  area: string;
  capacity: string;
  description: string;
  image: string;
  images?: string[];
  amenities?: string[];
  price?: string;
}

const { 
  name, 
  area, 
  capacity, 
  description, 
  image, 
  images = [],
  amenities = [],
  price
} = Astro.props;
---

<article class="bg-white rounded-xl overflow-hidden shadow-md hover:shadow-lg transition-shadow">
  <div class="relative">
    <img 
      src={image} 
      alt={name}
      class="w-full h-56 object-cover"
      loading="lazy"
    />
    {price && (
      <div class="absolute top-4 right-4 bg-primary text-white px-3 py-1 rounded-full text-sm font-medium">
        {price}
      </div>
    )}
  </div>
  
  <div class="p-6">
    <h3 class="font-playfair text-xl font-semibold text-primary mb-2">
      {name}
    </h3>
    
    <div class="flex flex-wrap gap-3 text-sm text-gray-500 mb-4">
      <span class="flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
        </svg>
        {area}
      </span>
      <span class="flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
        {capacity}
      </span>
    </div>
    
    <p class="text-gray-600 text-sm mb-4">
      {description}
    </p>
    
    {amenities.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-4">
        {amenities.slice(0, 4).map((amenity) => (
          <span class="bg-cream text-xs px-2 py-1 rounded-full text-charcoal">
            {amenity}
          </span>
        ))}
        {amenities.length > 4 && (
          <span class="text-xs text-gray-500">+{amenities.length - 4} ещё</span>
        )}
      </div>
    )}
    
    <a 
      href="#booking"
      class="inline-flex items-center gap-2 text-primary font-medium text-sm hover:text-primary-dark transition-colors"
    >
      Забронировать
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</article>
