---
interface Props {
  images: string[];
  alt: string;
  class?: string;
}

const { images, alt, class: className = '' } = Astro.props;
---

<div class={`grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 ${className}`}>
  {images.map((image, index) => (
    <div class="relative group overflow-hidden rounded-lg aspect-square">
      <img 
        src={image} 
        alt={`${alt} ${index + 1}`}
        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors cursor-pointer" />
    </div>
  ))}
</div>
