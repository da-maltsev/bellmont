---
const basePath = import.meta.env.BASE_PATH || '/';
const base = basePath === '/' ? '' : basePath;
const services = [
  { href: `${base}/hotel`, label: 'Гостиница' },
  { href: `${base}/restaurant`, label: 'Ресторан' },
  { href: `${base}/amenities`, label: 'Баня и бассейн' },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-charcoal text-white mt-auto">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-primary rounded-full flex items-center justify-center">
            <span class="text-white font-bold text-lg font-playfair">Б</span>
          </div>
          <span class="font-playfair text-xl font-bold">Бельмонт</span>
        </div>
        <p class="text-gray-400 text-sm">
          Современный мини-отель семейного типа в центре Златоуста
        </p>
      </div>

      <div>
        <h4 class="font-semibold mb-4 text-white">Услуги</h4>
        <ul class="space-y-2">
          {services.map((item) => (
            <li>
              <a href={item.href} class="text-gray-400 hover:text-white transition-colors text-sm">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-semibold mb-4 text-white">Контакты</h4>
        <ul class="space-y-2 text-sm text-gray-400">
          <li>г. Златоуст, ул. Таганайская, 194 А</li>
          <li>
            <a href="tel:+79068628866" class="hover:text-white transition-colors">
              8 (906) 862-88-66
            </a>
          </li>
          <li>
            <a href="tel:+73513655700" class="hover:text-white transition-colors">
              8 (3513) 655-700
            </a>
          </li>
          <li>
            <a href="mailto:info@hotel-bellmont.ru" class="hover:text-white transition-colors">
              info@hotel-bellmont.ru
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold mb-4 text-white">Бронирование</h4>
        <a 
          href="https://tl.hotelote.ru/widget?hotelId=102988" 
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block bg-primary hover:bg-primary-dark text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors"
        >
          Забронировать номер
        </a>
      </div>
    </div>

    <div class="border-t border-gray-700 mt-8 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-sm text-gray-400">
        © {currentYear} Гостиничный комплекс "Бельмонт". Все права защищены.
      </p>
      <div class="flex items-center gap-4">
        <a 
          href="https://vk.com/hotelbellmont" 
          target="_blank" 
          rel="noopener noreferrer"
          class="text-gray-400 hover:text-white transition-colors"
          aria-label="ВКонтакте"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M15.684 0H8.316C1.592 0 0 1.592 0 8.316v7.368C0 22.408 1.592 24 8.316 24h7.368C22.408 24 24 22.408 24 15.684V8.316C24 1.592 22.408 0 15.684 0zm3.692 17.123h-1.744c-.66 0-.864-.525-2.05-1.727-1.033-1-1.49-1.135-1.744-1.135-.356 0-.458.102-.458.593v1.575c0 .424-.135.678-1.253.678-1.846 0-3.896-1.12-5.339-3.202-2.17-3.04-2.763-5.32-2.763-5.79 0-.254.102-.491.593-.491h1.744c.44 0 .61.203.78.678.847 2.455 2.27 4.607 2.853 4.607.22 0 .322-.102.322-.66V9.729c-.068-1.186-.695-1.287-.695-1.71 0-.203.17-.407.44-.407h2.744c.373 0 .508.203.508.644v3.473c0 .372.17.508.271.508.22 0 .407-.136.813-.542 1.254-1.406 2.15-3.574 2.15-3.574.119-.254.322-.491.763-.491h1.744c.525 0 .644.27.525.644-.22 1.017-2.354 4.031-2.354 4.031-.186.305-.254.44 0 .78.186.254.796.779 1.203 1.253.745.847 1.32 1.558 1.473 2.05.17.475-.085.72-.576.72z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
