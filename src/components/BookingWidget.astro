---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div class={`booking-widget ${className}`}>
  <a 
    href="https://tl.hotelote.ru/widget?hotelId=102988" 
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-2 bg-secondary hover:bg-secondary-dark text-charcoal font-semibold px-6 py-3 rounded-lg transition-colors"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
    </svg>
    Забронировать номер
  </a>
  <p class="text-xs text-gray-500 mt-2">Лучшие тарифы на официальном сайте</p>
</div>
