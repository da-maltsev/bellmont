---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import ContactInfo from '../components/ContactInfo.astro';
import BookingWidget from '../components/BookingWidget.astro';
---

<BaseLayout 
  title="Контакты"
  description="Контакты гостиничного комплекса Бельмонт в Златоусте. Телефоны, адрес, схема проезда."
>
  <Header />
  
  <main>
    <Hero 
      title="Контакты"
      subtitle="Свяжитесь с нами любым удобным способом"
    />
    
    <Section>
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <ContactInfo />
          
          <div class="mt-8 p-6 bg-cream rounded-xl">
            <h3 class="font-playfair text-xl font-semibold text-primary mb-4">
              Время работы
            </h3>
            <ul class="space-y-2 text-gray-600">
              <li class="flex justify-between">
                <span>Стойка регистрации</span>
                <span class="font-medium">Круглосуточно</span>
              </li>
              <li class="flex justify-between">
                <span>Завтрак</span>
                <span class="font-medium">07:00 — 10:00</span>
              </li>
              <li class="flex justify-between">
                <span>Служба бронирования</span>
                <span class="font-medium">09:00 — 21:00</span>
              </li>
            </ul>
          </div>
          
          <div class="mt-8">
            <h3 class="font-playfair text-xl font-semibold text-primary mb-4">
              Как нас найти
            </h3>
            <p class="text-gray-600 mb-4">
              Гостиница расположена в центре Златоуста, в непосредственной близости от остановки 
              общественного транспорта «Гостиница «Бельмонт».
            </p>
            <p class="text-gray-600">
              От ж/д вокзала Златоуста: автобусы № 1, 5, 15 до остановки «Гостиница Бельмонт». 
              Время в пути ~15 минут.
            </p>
          </div>
        </div>
        
        <div>
          <div class="bg-white rounded-xl shadow-md p-6 mb-8">
            <h3 class="font-playfair text-xl font-semibold text-primary mb-6">
              Напишите нам
            </h3>
            <form class="space-y-4">
              <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Ваше имя</label>
                <input 
                  type="text" 
                  id="name" 
                  name="name"
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors"
                  placeholder="Иван Иванов"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Телефон</label>
                <input 
                  type="tel" 
                  id="phone" 
                  name="phone"
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors"
                  placeholder="+7 (___) ___-__-__"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                <input 
                  type="email" 
                  id="email" 
                  name="email"
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors"
                  placeholder="email@example.com"
                />
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Сообщение</label>
                <textarea 
                  id="message" 
                  name="message"
                  rows="4"
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors resize-none"
                  placeholder="Ваш вопрос..."
                ></textarea>
              </div>
              <button 
                type="submit"
                class="w-full bg-primary text-white font-medium py-3 rounded-lg hover:bg-primary-dark transition-colors"
              >
                Отправить
              </button>
              <p class="text-xs text-gray-500 text-center">
                Отправляя форму, вы даете согласие на обработку персональных данных
              </p>
            </form>
          </div>
          
          <div class="bg-white rounded-xl shadow-md p-6">
            <h3 class="font-playfair text-xl font-semibold text-primary mb-4">
              Онлайн-бронирование
            </h3>
            <p class="text-gray-600 mb-4">
              Забронируйте номер на официальном сайте по лучшим тарифам
            </p>
            <BookingWidget />
          </div>
        </div>
      </div>
    </Section>
    
    <Section class="bg-white">
      <div class="rounded-xl overflow-hidden shadow-md">
        <iframe 
          src="https://yandex.ru/map-widget/v1/?um=constructor%3A0&amp;source=constructor&amp;ll=59.656944%2C54.989722&amp;z=16&amp;pt=59.656944%2C54.989722%2Cpm2rdm"
          width="100%" 
          height="450" 
          frameborder="0"
          style="border: 0;"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    </Section>
  </main>
  
  <Footer />
</BaseLayout>
