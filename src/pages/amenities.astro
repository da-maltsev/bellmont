---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import BookingWidget from '../components/BookingWidget.astro';

const amenities = [
  {
    id: 'bathhouse',
    title: 'Баня и бассейн',
    description: 'Отдохните и восстановите силы в нашем банном комплексе всей семьей. Русская баня с бассейном вместимостью до 8 человек.',
    image: 'https://hotel-bellmont.ru/images/bassein.jpg',
    features: ['Русская баня', 'Бассейн', 'Вместимость до 8 человек', 'Отапливаемые беседки']
  },
  {
    id: 'billiards',
    title: 'Бильярд',
    description: 'Проведите время с удовольствием, сыграв партию в американский пул в уютной обстановке нашего отеля.',
    image: 'https://hotel-bellmont.ru/images/biliard.jpg',
    features: ['Американский пул', 'Профессиональный стол', 'Уютная атмосфера']
  },
  {
    id: 'banquet',
    title: 'Банкетные залы',
    description: 'Просторные банкетные залы для свадеб, юбилеев, корпоративов и конференций.',
    image: 'https://hotel-bellmont.ru/images/banket.jpg',
    features: [
      'Зал «Прованс» — до 30 персон',
      'Зал «Шампань» — до 70 персон',
      'Конференц-возможности',
      'Профессиональное оборудование'
    ]
  },
  {
    id: 'gazebo',
    title: 'Беседки с барбекю',
    description: 'Уютные отапливаемые беседки для отдыха на свежем воздухе с возможностью приготовления блюд на огне.',
    image: 'https://hotel-bellmont.ru/images/terrasa.jpg',
    features: [
      'Беседка на 12 человек',
      'Беседка на 40 человек',
      'Мангал / барбекю',
      'Отапливаемые'
    ]
  },
  {
    id: 'playground',
    title: 'Детская и спортивная площадки',
    description: 'Для маленьких гостей и любителей активного отдыха.',
    image: 'https://hotel-bellmont.ru/images/playground.jpg',
    features: ['Детская площадка', 'Спортивная площадка для Воркаута', 'Безопасное покрытие']
  },
];
---

<BaseLayout 
  title="Услуги"
  description="Услуги гостиничного комплекса Бельмонт: баня, бассейн, бильярд, банкетные залы, беседки с барбекю."
>
  <Header />
  
  <main>
    <Hero 
      title="Услуги комплекса"
      subtitle="Гостиничный комплекс «Бельмонт» предлагает широкий спектр услуг для комфортного отдыха"
    />
    
    <Section>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {amenities.map((amenity) => (
          <div id={amenity.id} class="bg-white rounded-xl overflow-hidden shadow-md scroll-mt-24">
            <img 
              src={amenity.image} 
              alt={amenity.title}
              class="w-full h-48 object-cover"
              loading="lazy"
            />
            <div class="p-6">
              <h3 class="font-playfair text-xl font-semibold text-primary mb-2">
                {amenity.title}
              </h3>
              <p class="text-gray-600 text-sm mb-4">
                {amenity.description}
              </p>
              <ul class="space-y-1">
                {amenity.features.map((feature) => (
                  <li class="flex items-center gap-2 text-sm text-gray-500">
                    <svg class="w-4 h-4 text-secondary flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </Section>
    
    <Section class="bg-white" id="transfer">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-playfair text-3xl font-bold text-primary mb-6">
            Трансфер из аэропорта
          </h2>
          <p class="text-gray-600 mb-4">
            Встретим вас из аэропорта на нашем комфортном Mercedes-Benz GL и доставим прямо к отелю.
          </p>
          <ul class="space-y-3">
            <li class="flex items-center justify-between py-3 border-b border-gray-100">
              <span class="font-medium">Челябинск</span>
              <span class="text-primary font-semibold">6 000 ₽</span>
            </li>
            <li class="flex items-center justify-between py-3 border-b border-gray-100">
              <span class="font-medium">Екатеринбург</span>
              <span class="text-primary font-semibold">8 000 ₽</span>
            </li>
          </ul>
          <a 
            href="tel:+79068628866" 
            class="inline-flex items-center gap-2 mt-6 bg-primary text-white font-medium px-6 py-3 rounded-lg hover:bg-primary-dark transition-colors"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Заказать трансфер
          </a>
        </div>
        <div class="bg-cream rounded-xl p-8">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-16 h-16 bg-primary rounded-full flex items-center justify-center">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-primary">Mercedes-Benz GL</h4>
              <p class="text-sm text-gray-500">Комфортный представительский SUV</p>
            </div>
          </div>
          <ul class="space-y-2 text-sm text-gray-600">
            <li>• Вместимость до 7 пассажиров</li>
            <li>• Кондиционер</li>
            <li>• Просторный багажник</li>
            <li>• Детские кресла по запросу</li>
          </ul>
        </div>
      </div>
    </Section>
    
    <Section id="booking">
      <div class="text-center">
        <h2 class="font-playfair text-3xl font-bold text-primary mb-4">
          Забронировать услуги
        </h2>
        <p class="text-gray-600 max-w-2xl mx-auto mb-8">
          Забронируйте номер в гостинице «Бельмонт» и воспользуйтесь всеми услугами комплекса
        </p>
        <BookingWidget />
      </div>
    </Section>
  </main>
  
  <Footer />
</BaseLayout>
